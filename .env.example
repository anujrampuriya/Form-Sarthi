# FormSarthi — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — change this before deploying!
JWT_SECRET=formsarthi_secret_change_in_production_12345

# Chrome Extension ID — update with your actual extension ID from chrome://extensions
CHROME_EXTENSION_ID=your-extension-id-here
