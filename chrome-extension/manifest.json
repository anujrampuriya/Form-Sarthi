{
  "manifest_version": 3,
  "name": "FormSarthi",
  "version": "1.0.0",
  "description": "Auto-fill Indian government & college forms using your securely stored profile data.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:4000/*",
    "http://127.0.0.1:3000/*",
    "http://127.0.0.1:4000/*",
    "https://your-deployed-domain.com/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "FormSarthi"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
